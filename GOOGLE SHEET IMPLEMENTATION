# Google Sheets Implementation

## Step 1: Create Google Sheet

1. Open Google Sheets
2. Create a new spreadsheet
3. Rename the sheet as:
   RFID Attendance System

## Step 2: Open Apps Script

1. In Google Sheets, click:
   Extensions → Apps Script
2. Delete default code
3. Paste the Google Apps Script code

## Step 3: Paste the Script

```javascript
function doGet(e) {
  var sheet = SpreadsheetApp.getActiveSpreadsheet().getActiveSheet();

  var headers = ["Name", "Entry/Exit", "RFID", "Date", "Time"];
  var firstRow = sheet.getRange(1, 1, 1, headers.length).getValues()[0];

  if (firstRow.join("") === "") {
    sheet.getRange(1, 1, 1, headers.length).setValues([headers]);
  }

  if (!e || !e.parameter) {
    return ContentService.createTextOutput(
      JSON.stringify({status:"error", message:"No parameters received"})
    ).setMimeType(ContentService.MimeType.JSON);
  }

  var name  = e.parameter.name  || "Unknown";
  var entry = e.parameter.entry || "ENTRY";
  var rfid  = e.parameter.rfid  || "";
  var date  = e.parameter.date  || "";
  var time  = e.parameter.time  || "";

  var rowData = [name, entry, rfid, date, time];
  sheet.appendRow(rowData);

  return ContentService.createTextOutput(
    JSON.stringify({status:"success", name, entry, rfid, date, time})
  ).setMimeType(ContentService.MimeType.JSON);
}
```

